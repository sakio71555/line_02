# Staging env contract for copy-based release archive tests.
# This file is intentionally not named .env* so release archives can include it
# while still excluding real dotenv files.
# Do not paste real values into this file.

# App runtime
APP_ENV=staging
TENANT_ID=tenant_amamihome
TENANT_SLUG=amamihome

# Repository runtime safety
REPOSITORY_RUNTIME=in_memory

# Supabase staging
# SUPABASE_SERVICE_ROLE_KEY is server-side only.
# Never expose it to browser, LIFF, or Next.js client components.
# SUPABASE_DB_URL is for migration / DB verification only.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# LINE staging / test channel - disabled by default
# Use a staging/test channel only.
# Do not enable real LINE sending in this Loop.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_SECRET_PATH=
STAFF_LINE_GROUP_ID=
LINE_MESSAGING_ENABLED=false
LINE_REAL_PUSH_ENABLED=false

# OpenAI / GPT staging - mock by default
# Do not call OpenAI until a later Loop explicitly enables it.
OPENAI_API_KEY=
OPENAI_MODEL=
AI_PROVIDER=mock

# Admin / app URLs
APP_BASE_URL=
API_BASE_URL=
LIFF_BASE_URL=
