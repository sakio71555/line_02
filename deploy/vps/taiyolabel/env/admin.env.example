# amami-line-crm Admin production env example for future VPS deployment.
# Copy manually on the VPS to /etc/amami-line-crm/admin.env.
# Never commit filled values.

APP_ENV=production
NODE_ENV=production
TENANT_ID=tenant_amamihome
TENANT_SLUG=amamihome

# Planned local binding
ADMIN_HOST=127.0.0.1
ADMIN_PORT=3002
PORT=3002

# Admin API access
API_BASE_URL=https://api.taiyolabel.site
ADMIN_PUBLIC_ORIGIN=https://admin.taiyolabel.site
API_PUBLIC_ORIGIN=https://api.taiyolabel.site
ADMIN_API_INCLUDE_DEV_TENANT_HEADER=false

# Supabase Auth client boundary. Fill on VPS, never in git.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# These server-side values do not belong in browser/client components.
# Keep blank unless a later server-side boundary explicitly needs them.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# LINE and OpenAI are not called by Admin UI directly.
LINE_MESSAGING_ENABLED=false
LINE_REAL_PUSH_ENABLED=false
AI_PROVIDER=mock
OPENAI_REAL_API_ENABLED=false
