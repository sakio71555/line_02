# amami-line-crm API production env example for future VPS deployment.
# Copy manually on the VPS to /etc/amami-line-crm/api.env.
# Never commit filled values.

APP_ENV=production
NODE_ENV=production
TENANT_ID=tenant_amamihome
TENANT_SLUG=amamihome

# Runtime mode
REPOSITORY_RUNTIME=supabase
AUTH_SESSION_VERIFIER=supabase

# Planned local binding.
# apps/api resolves API_HOST first, then HOST, then 127.0.0.1 in production.
# apps/api resolves API_PORT first, then PORT, then 8788 in production.
API_HOST=127.0.0.1
HOST=127.0.0.1
API_PORT=8788
PORT=8788

# Public origins
ADMIN_PUBLIC_ORIGIN=https://admin.taiyolabel.site
API_PUBLIC_ORIGIN=https://api.taiyolabel.site
APP_BASE_URL=https://admin.taiyolabel.site
API_BASE_URL=https://api.taiyolabel.site

# Supabase - server-side only. Fill on VPS, never in git.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# LINE - disabled until explicit real smoke approval.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_SECRET_PATH=
STAFF_LINE_GROUP_ID=
LINE_MESSAGING_ENABLED=false
LINE_REAL_PUSH_ENABLED=false

# OpenAI - mock until explicit real smoke approval.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REAL_API_ENABLED=false
