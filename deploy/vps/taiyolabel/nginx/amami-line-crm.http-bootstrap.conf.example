# amami-line-crm HTTP bootstrap example for a future real domain.
# Repo documentation only. Do not copy into an active Nginx include tree without a dedicated approval Loop.
# Replace _CHANGE_ME_ with the approved canonical hostname only after domain ownership and DNS are confirmed.

server {
    listen 80;
    listen [::]:80;
    server_name _CHANGE_ME_;

    client_max_body_size 10m;

    # Optional ACME HTTP-01 webroot for a future certificate issuance Loop.
    # Keep this placeholder out of production until the ACME method is approved.
    location ^~ /.well-known/acme-challenge/ {
        root _ACME_WEBROOT_CHANGE_ME_;
        default_type "text/plain";
        try_files $uri =404;
    }

    # Temporary diagnostic marker for pre-public routing checks.
    # Remove or explicitly approve this header before public production enablement.
    add_header X-Amami-Line-Crm-Proxy "amami-line-crm-http-bootstrap" always;

    location = /api/health {
        proxy_pass http://127.0.0.1:8788/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8788/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    location / {
        proxy_pass http://127.0.0.1:3100;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
